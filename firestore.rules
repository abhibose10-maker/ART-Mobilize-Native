rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth.uid != null;
    }

    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function userDivisionMatches(userDivision, resourceDivision) {
      return userDivision == resourceDivision;
    }

    function userUnitMatches(userData, resource) {
      return userData.division == resource.division 
        && userData.artType == resource.artType 
        && userData.artLocation == resource.artLocation;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        getUserRole(request.auth.uid) == 'SuperAdmin'
      );
      
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        getUserRole(request.auth.uid) == 'SuperAdmin'
      );
    }

    // Alerts collection
    match /alerts/{alertId} {
      allow read: if isSignedIn() && (
        (getUserRole(request.auth.uid) == 'SuperAdmin' && 
         getUserData(request.auth.uid).division == resource.data.division) ||
        (getUserRole(request.auth.uid) == 'Admin' && 
         userUnitMatches(getUserData(request.auth.uid), resource.data)) ||
        (getUserRole(request.auth.uid) == 'Staff' && 
         userUnitMatches(getUserData(request.auth.uid), resource.data))
      );

      allow create: if isSignedIn() && (
        (getUserRole(request.auth.uid) == 'SuperAdmin' && 
         request.resource.data.division == getUserData(request.auth.uid).division) ||
        (getUserRole(request.auth.uid) == 'Admin' && 
         userUnitMatches(getUserData(request.auth.uid), request.resource.data))
      );

      allow update: if isSignedIn() && (
        (getUserRole(request.auth.uid) == 'SuperAdmin' && 
         resource.data.division == getUserData(request.auth.uid).division) ||
        (getUserRole(request.auth.uid) == 'Admin' && 
         userUnitMatches(getUserData(request.auth.uid), resource.data))
      );
    }

    // Acknowledgements collection
    match /acknowledgements/{ackId} {
      allow read: if isSignedIn() && (
        (getUserRole(request.auth.uid) == 'SuperAdmin' && 
         getUserData(request.auth.uid).division == resource.data.division) ||
        (getUserRole(request.auth.uid) == 'Admin' && 
         userUnitMatches(getUserData(request.auth.uid), resource.data)) ||
        (getUserRole(request.auth.uid) == 'Staff' && 
         request.auth.uid == resource.data.userId)
      );

      allow create: if isSignedIn() && 
        getUserRole(request.auth.uid) == 'Staff' &&
        request.auth.uid == request.resource.data.userId &&
        userUnitMatches(getUserData(request.auth.uid), request.resource.data);

      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        getUserRole(request.auth.uid) == 'SuperAdmin'
      );
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}